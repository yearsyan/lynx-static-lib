+void TraceFetch(const char* format, ...) {
+  const char* path = std::getenv("LYNXLIB_FETCH_TRACE");
+  if (!path || path[0] == '\0') {
+    return;
+  }
+
+  static std::mutex trace_mutex;
+  std::lock_guard<std::mutex> lock(trace_mutex);
+  std::FILE* file = std::fopen(path, "ab");
+  if (!file) {
+    return;
+  }
+  std::fprintf(file, "[lynx-fetch-module] ");
+  va_list args;
+  va_start(args, format);
+  std::vfprintf(file, format, args);
+  va_end(args);
+  std::fputc('\n', file);
+  std::fclose(file);
+}
+
